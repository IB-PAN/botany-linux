{
  "policies": {
    "ManagedBookmarks": [
      {
        "toplevel_name": "Instytut Botaniki"
      },
      {
        "name": "Strona Instytutu Botaniki",
        "url": "https://botany.pl"
      },
      {
        "name": "Poczta Google",
        "url": "https://mail.google.com"
      },
      {
        "name": "Różne",
        "children": [
          {
            "name": "Repozytorium Cyfrowe Instytutów Naukowych — IB PAN",
            "url": "https://rcin.org.pl/dlibra/collectiondescription/428"
          },
          {
            "name": "Katalog biblioteki",
            "url": "https://biblioteka.botany.pl/"
          }
        ]
      }
    ],
    "FirefoxHome": {
      "SponsoredTopSites": false,
      "Pocket": false,
      "SponsoredPocket": false
    },
    "NoDefaultBookmarks": true,
    "SearchEngines": {
      "Add": [
        {
          "Name": "Biblioteka IB PAN",
          "URLTemplate": "https://biblioteka.botany.pl/search?q={searchTerms}",
          "Method": "GET",
          "IconURL": "https://biblioteka.botany.pl/zasoby/favicon.png",
          "Alias": "@bib",
          "Description": "Przeszukaj katalog biblioteczny IB PAN"
        },
        {
          "Name": "NUKAT",
          "URLTemplate": "https://katalog.nukat.edu.pl/search?q={searchTerms}",
          "Method": "GET",
          "IconURL": "https://centrum.nukat.edu.pl/images/logotypy/logo/png/favico_violet.ico",
          "Alias": "@nukat",
          "Description": "Przeszukaj katalog biblioteczny NUKAT"
        }
      ]
    },
    "SkipTermsOfUse": true,
    "Handlers": {
      "schemes": {
        "mailto": {
          "action": "useHelperApp",
          "ask": false,
          "handlers": [{
            "name": "Gmail",
            "uriTemplate": "https://mail.google.com/mail/?extsrc=mailto&url=%s"
          }]
        }
      }
    },
    "ExtensionSettings": {
      "browser-extension-linux@botany.edu.pl": {
        "installation_mode": "force_installed",
        "install_url": "file:///app/etc/firefox/firefox-extension.xpi",
        "private_browsing": true
      },
      "plasma-browser-integration@kde.org": {
        "installation_mode": "normal_installed",
        "install_url": "https://addons.mozilla.org/firefox/downloads/file/4298512/latest.xpi",
        "private_browsing": true
      }
    },
    "OverrideFirstRunPage": ""
  }
}
