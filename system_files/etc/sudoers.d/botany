# Anyone using `sudo -u botany_adm` to be asked botany_adm's password instead of their own
Defaults>BOTANY_ADM targetpw

# Allow anyone using `sudo -u botany_adm` to run `sudo` this way (after authenticating properly)
# /usr/sbin/sudo
ALL ALL=(botany_adm) /usr/sbin/sudo, /bin/bash

# Don't ask for password when botany_adm uses sudo
botany_adm ALL=(ALL) NOPASSWD: ALL

# Password typing feedback
Defaults pwfeedback
